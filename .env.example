# Database mode: MEMORY (no PostgreSQL needed) or POSTGRES (default)
USE_DATABASE_MODE=MEMORY

# PostgreSQL (only needed when USE_DATABASE_MODE=POSTGRES)
DATABASE_URL=postgresql://postgres.[YOUR-URL]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# Auth (only needed when USE_DATABASE_MODE=POSTGRES)
BETTER_AUTH_SECRET=...
BETTER_AUTH_URL=http://localhost:3000